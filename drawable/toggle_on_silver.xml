<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Track background (silver) -->
    <item android:top="7dp" android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="100dp" />
        </shape>
    </item>
    <!-- Thumb (dark circle, right-aligned) -->
    <item>
        <inset android:insetLeft="15dp" android:insetTop="8dp" android:insetRight="1dp" android:insetBottom="8dp">
            <shape android:shape="oval">
                <solid android:color="#0D1117" />
            </shape>
        </inset>
    </item>
</layer-list>
