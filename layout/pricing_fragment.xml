<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/pricing_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:tag="secondary"
            android:text="@string/menu_pricing_description"
            android:textSize="12sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/pricing_card_free"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/pricing_badge_free"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="@string/pricing_free_badge"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:tag="secondary" android:text="Essential FastFlag controls" android:textSize="10sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:tag="primary"
                        android:text="@string/pricing_free_name"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:tag="primary"
                        android:text="@string/pricing_free_price"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/surfaceStroke" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_ads" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_gray_sky" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_fps_display" android:textSize="11sp" />

                    <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />

                    <TextView
                        android:id="@+id/pricing_button_free"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="@string/pricing_current_plan"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pricing_card_plus"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="6dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/pricing_badge_plus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="@string/pricing_plus_badge"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:tag="secondary" android:text="Advanced tools, billed monthly" android:textSize="10sp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:tag="primary" android:text="@string/pricing_plus_name" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:tag="primary" android:text="@string/pricing_plus_price" android:textSize="16sp" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@color/surfaceStroke" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_no_ads" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_gray_sky" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_fps_display" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_desync" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_physics" android:textSize="11sp" />
                    <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                    <TextView
                        android:id="@+id/pricing_button_plus"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/pricing_contact_to_buy"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pricing_card_max"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/pricing_badge_max"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="@string/pricing_max_badge"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:tag="secondary" android:text="Everything unlocked, forever" android:textSize="10sp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:tag="primary" android:text="@string/pricing_max_name" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:tag="primary" android:text="@string/pricing_max_price" android:textSize="16sp" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@color/surfaceStroke" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_no_ads" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_gray_sky" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_fps_display" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_desync" android:textSize="11sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="9dp" android:tag="feature" android:text="@string/pricing_physics" android:textSize="11sp" />
                    <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                    <TextView
                        android:id="@+id/pricing_button_max"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/pricing_contact_to_buy"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/pricing_license_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:tag="primary"
                android:text="@string/pricing_license_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:tag="secondary"
                android:text="@string/pricing_license_description"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/pricing_license_input"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_masterstrap_chip"
                    android:hint="@string/pricing_license_hint"
                    android:inputType="textCapCharacters"
                    android:maxLength="25"
                    android:paddingHorizontal="10dp"
                    android:singleLine="true"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/pricing_license_activate"
                    android:layout_width="100dp"
                    android:layout_height="36dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/pricing_license_activate"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/pricing_license_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:tag="secondary"
                android:text="@string/pricing_license_free_status"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
