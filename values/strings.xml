    <string name="menu_fastflag_preset_disable_terrain_title">Disable terrain textures</string>
    <string name="menu_fastflag_preset_disable_terrain_description">Reduces terrain texture-array work using a map-backed Android flag.</string>
    <string name="menu_fastflag_preset_low_texture_title">Low-texture mode</string>
    <string name="menu_fastflag_preset_low_texture_description">Skips high-resolution mip levels to reduce texture memory pressure.</string>
    <string name="menu_fastflag_preset_android_mesh_cache_title">Android mesh-cache optimization</string>
